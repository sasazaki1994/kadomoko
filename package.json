{
  "name": "kado-moco",
  "private": true,
  "version": "0.1.0",
  "description": "KadoMoco - a tiny desktop-resident pixel pet",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "npm run prepare:sheet && npm run validate:sprite:check && tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "preview": "vite preview",
    "generate:sheet": "node scripts/generate-placeholder-sheet.mjs",
    "test": "node scripts/clean-test-output.mjs && tsc -p tsconfig.test.json && node --test .tmp-tests/test/**/*.test.js",
    "package:win": "npm run build && electron-builder --win --publish=never",
    "dist:win": "npm run package:win",
    "validate:sprite": "npm run prepare:sheet && npm run validate:sprite:check",
    "test:e2e": "npm run build && node --test e2e/**/*.test.mjs",
    "verify:package:win": "node scripts/verify-windows-package.mjs",
    "prepare:sheet": "node scripts/prepare-production-sprite-sheet.mjs",
    "validate:sprite:check": "node scripts/validate-sprite-sheet.mjs"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.1",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vite": "^6.0.7",
    "vite-plugin-electron": "^0.29.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.kadomoco.app",
    "productName": "KadoMoco",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "!**/*.map",
      "!test{,/**}",
      "!e2e{,/**}",
      "!spec{,/**}",
      "!scripts{,/**}",
      "!src{,/**}"
    ],
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "executableName": "KadoMoco"
    },
    "extraMetadata": {
      "main": "dist-electron/main.js"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
